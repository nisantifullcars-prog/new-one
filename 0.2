/* ---------- admin ---------- */
function renderAdmin(){
  const q = (document.getElementById('searchAdmin')?.value || '').trim().toLowerCase();
  let list = cars.slice();
  if(q) list = list.filter(c => [c.car_number,c.customer_name,c.customer_id].some(v => (v||'').toLowerCase().includes(q)));
  list.sort((a,b)=>(b.created_at||'').localeCompare(a.created_at||''));
  const body = document.getElementById('adminTableBody');
  if(list.length===0){ body.innerHTML = `<tr><td colspan="12" style="text-align:center;color:var(--ink-soft);padding:26px;">אין נתונים להצגה.</td></tr>`; return; }
  body.innerHTML = list.map(adminRowHTML).join('');
}
function adminRowHTML(car){
  return `<tr data-row="${car.id}">
    <td><input class="mono" value="${esc(car.car_number)}" oninput="quick('${car.id}','car_number',this.value)" onchange="saveCars()"></td>
    <td><input value="${esc(car.model)}" oninput="quick('${car.id}','model',this.value)" onchange="saveCars()"></td>
    <td><select onchange="updateStatus('${car.id}', this.value)">
      <option value="garage" ${car.status==='garage'?'selected':''}>במוסך</option>
      <option value="inventory" ${car.status==='inventory'?'selected':''}>במלאי</option>
      <option value="delivered" ${car.status==='delivered'?'selected':''}>נמסר</option>
    </select></td>
    <td><input value="${esc(car.customer_name)}" oninput="quick('${car.id}','customer_name',this.value)" onchange="saveCars()"></td>
    <td><input class="mono" value="${esc(car.customer_id)}" oninput="quick('${car.id}','customer_id',this.value)" onchange="saveCars()"></td>
    <td><input class="mono" value="${esc(car.customer_phone)}" oninput="quick('${car.id}','customer_phone',this.value)" onchange="saveCars()"></td>
    <td><input type="date" value="${esc(car.entry_garage_date)}" onchange="updateCarField('${car.id}','entry_garage_date',this.value)"></td>
    <td><input type="date" value="${esc(car.entry_inventory_date)}" onchange="updateCarField('${car.id}','entry_inventory_date',this.value)"></td>
    <td><input value="${esc(car.salesperson)}" oninput="quick('${car.id}','salesperson',this.value)" onchange="saveCars()"></td>
    <td><input type="date" value="${esc(car.sold_date)}" onchange="updateCarField('${car.id}','sold_date',this.value)"></td>
    <td><input type="date" value="${esc(car.delivered_date)}" onchange="updateCarField('${car.id}','delivered_date',this.value)"></td>
    <td><button class="btn btn-danger" onclick="deleteCar('${car.id}')">מחק</button></td>
  </tr>`;
}
function updateStatus(id, val){
  const car = cars.find(c=>c.id===id);
  if(!car) return;
  car.status = val;
  if(val==='inventory' && !car.entry_inventory_date) car.entry_inventory_date = todayStr();
  if(val==='delivered' && !car.delivered_date) car.delivered_date = todayStr();
  saveCars();
  renderAll();
}
function deleteCar(id){
  if(!confirm('למחוק את הרכב לצמיתות? לא ניתן לשחזר פעולה זו.')) return;
  cars = cars.filter(c=>c.id!==id);
  deleteCarFromServer(id);
  renderAll();
}
function exportData(){
  try{
    const blob = new Blob([JSON.stringify(cars, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'inventory-backup-' + todayStr() + '.json';
    a.click();
    URL.revokeObjectURL(url);
  }catch(e){
    showToast('שגיאה בייצוא הנתונים', 'error');
  }
}
function resetAll(){
  if(!confirm('האם למחוק את כל הנתונים במערכת? פעולה זו בלתי הפיכה.')) return;
  resetAllOnServer();
  cars = [];
  renderAll();
  showToast('כל הנתונים נמחקו', 'success');
}

/* ---------- init ---------- */
async function init(){
  await loadCars();
  document.getElementById('loader').style.display = 'none';
  const entryDateEl = document.getElementById('f_entry_date');
  if(entryDateEl) entryDateEl.value = todayStr();
  renderAll();
}
init();
</script>
</body>
</html>
