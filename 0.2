function markSold(id){
  const input = document.getElementById('sp-'+id);
  const sp = input ? input.value.trim() : '';
  if(!sp){ showToast('נא להזין שם איש מכירות לפני סימון כנמכר', 'error'); return; }
  const car = cars.find(c=>c.id===id);
  if(!car) return;
  car.salesperson = sp;
  car.sold_date = todayStr();
  saveCars();
  renderAll();
  showToast('הרכב סומן כנמכר', 'success');
}
function markDelivered(id){
  const card = document.querySelector(`[data-card="${id}"]`);
  if(card) card.classList.add('stamping');
  setTimeout(()=>{
    const car = cars.find(c=>c.id===id);
    if(car){ car.status = 'delivered'; car.delivered_date = todayStr(); }
    saveCars();
    renderAll();
    showToast('הרכב נמסר ללקוח בהצלחה', 'success');
  }, 480);
}

