    <div class="row" style="align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <span class="plate mono">${esc(car.car_number)}</span>
        <span class="pill sold"><span class="dot"></span>נמכר ב-${esc(formatDateHe(car.sold_date))}</span>
      </div>
      <button class="btn btn-stamp" onclick="markDelivered('${car.id}')">✓ נמסר ללקוח</button>
    </div>
    <div class="row">
      <div class="field"><label>איש מכירות</label><input value="${esc(car.salesperson)}" oninput="quick('${car.id}','salesperson',this.value)" onchange="saveCars()"></div>
      <div class="field"><label>לקוח</label><span class="static-val">${esc(car.customer_name)||'—'}</span></div>
      <div class="field"><label>טלפון</label><span class="static-val mono">${esc(car.customer_phone)||'—'}</span></div>
