<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ניהול מלאי רכבים</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@500;700;900&family=Assistant:wght@400;500;600;700&family=Roboto+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --graphite-900:#14181D;
    --graphite-700:#242B33;
    --steel-50:#EEF1F5;
    --paper:#FFFFFF;
    --ink:#1B2027;
    --ink-soft:#5B6572;
    --line:#DCE1E6;
    --amber:#E2933B;
    --amber-soft:#FBEBD8;
    --blue:#2F6FED;
    --blue-soft:#E4ECFD;
    --teal:#1D9A8F;
    --teal-soft:#DBF2EF;
    --slate:#7B8794;
    --slate-soft:#EBEDEF;
    --red:#C1443A;
    --red-soft:#F8E2E0;
    --radius:14px;
    --radius-sm:8px;
    --shadow: 0 1px 2px rgba(20,24,29,.06), 0 8px 24px -12px rgba(20,24,29,.18);
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--steel-50);color:var(--ink);font-family:'Assistant',sans-serif;}
  h1,h2,h3,h4{font-family:'Rubik',sans-serif;margin:0;}
  .mono{font-family:'Roboto Mono',monospace;}
  #app{display:flex;min-height:100vh;}
  .hidden{display:none !important;}

  /* Sidebar */
  .sidebar{width:250px;flex-shrink:0;background:var(--graphite-900);color:#fff;display:flex;flex-direction:column;padding:22px 16px;position:sticky;top:0;height:100vh;}
  .brand{font-family:'Rubik';font-weight:900;font-size:1.05rem;display:flex;align-items:center;gap:10px;padding:0 6px;}
  .brand .dot{width:10px;height:10px;border-radius:50%;background:var(--amber);box-shadow:0 0 10px 3px rgba(226,147,59,.55);flex-shrink:0;}
  .sidebar nav{display:flex;flex-direction:column;gap:3px;margin-top:22px;}
  .nav-btn{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:11px 12px;border-radius:10px;color:#C7CDD4;background:transparent;border:none;font-family:'Assistant';font-weight:500;font-size:.95rem;cursor:pointer;text-align:right;transition:background .15s,color .15s;width:100%;}
  .nav-btn:hover{background:var(--graphite-700);color:#fff;}
  .nav-btn.active{background:var(--graphite-700);color:#fff;}
  .nav-btn .badge{font-family:'Roboto Mono';font-size:.74rem;background:rgba(255,255,255,.1);padding:1px 8px;border-radius:20px;}
  .nav-btn.active .badge{background:var(--amber);color:#1B2027;font-weight:600;}
  .sidebar-foot{margin-top:auto;font-size:.72rem;color:#7B8794;padding:16px 6px 0;border-top:1px solid var(--graphite-700);margin-top:16px;padding-top:16px;}

  /* Content */
  .content{flex:1;min-width:0;padding:30px 40px;max-width:1360px;}
  .topbar{margin-bottom:22px;}
  .topbar h1{font-weight:900;font-size:1.55rem;margin-bottom:5px;}
  .topbar p{color:var(--ink-soft);margin:0;font-size:.93rem;max-width:640px;line-height:1.5;}

  /* KPI */
  .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:30px;}
  .kpi-card{background:var(--paper);border-radius:var(--radius);padding:18px 20px;box-shadow:var(--shadow);border-inline-start:4px solid var(--c,var(--blue));}
  .kpi-card .num{font-family:'Roboto Mono';font-weight:600;font-size:2.15rem;line-height:1;}
  .kpi-card .label{color:var(--ink-soft);font-size:.85rem;margin-top:8px;}
  .light{width:8px;height:8px;border-radius:50%;display:inline-block;margin-left:6px;vertical-align:middle;}
  .group-title{font-weight:700;font-size:1rem;margin:26px 0 12px;}

  /* Blocks & cards */
  .paper-block{background:var(--paper);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow);}
  .car-card{background:var(--paper);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px 20px;margin-bottom:14px;border:1px solid var(--line);transform-origin:center;}
  .car-card.stamping{animation:stampFx .48s ease forwards;}
  @keyframes stampFx{
    0%{transform:scale(1) rotate(0);}
    40%{transform:scale(1.025) rotate(-1deg);box-shadow:0 0 0 3px var(--teal) inset, var(--shadow);}
    70%{transform:scale(.98) rotate(.3deg);}
    100%{transform:scale(.92) rotate(0);opacity:0;}
  }
  .car-card.pulse{animation:pulseFx .45s ease;}
  @keyframes pulseFx{0%{box-shadow:0 0 0 0 rgba(29,154,143,.5), var(--shadow);}100%{box-shadow:0 0 0 10px rgba(29,154,143,0), var(--shadow);}}

  .row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px;}
  .row:last-child{margin-bottom:0;}
  .field{display:flex;flex-direction:column;gap:5px;flex:1;min-width:150px;}
  .field label{font-size:.72rem;color:var(--ink-soft);font-weight:600;letter-spacing:.01em;}
  .static-val{padding:8px 0;display:block;color:var(--ink);font-size:.92rem;}
  input,select,textarea{font-family:'Assistant';font-size:.92rem;padding:8px 10px;border:1px solid var(--line);border-radius:var(--radius-sm);background:#fff;color:var(--ink);width:100%;}
  textarea{resize:vertical;min-height:56px;}
  input:focus,select:focus,textarea:focus,button:focus-visible,.nav-btn:focus-visible{outline:2px solid var(--blue);outline-offset:2px;}

  .plate{background:var(--graphite-900);color:#fff;padding:6px 13px;border-radius:6px;font-weight:600;letter-spacing:.04em;font-size:.92rem;}

  .pill{display:inline-flex;align-items:center;gap:6px;font-size:.78rem;font-weight:600;padding:4px 11px;border-radius:20px;white-space:nowrap;}
  .pill .dot{width:7px;height:7px;border-radius:50%;}
  .pill.garage{background:var(--amber-soft);color:#8a5a17;}
  .pill.garage .dot{background:var(--amber);}
  .pill.inventory{background:var(--blue-soft);color:#1c47a8;}
  .pill.inventory .dot{background:var(--blue);}
  .pill.sold{background:var(--teal-soft);color:#0f5a53;}
  .pill.sold .dot{background:var(--teal);}
  .pill.delivered{background:var(--slate-soft);color:#48525c;}
  .pill.delivered .dot{background:var(--slate);}

  .section-label{font-weight:700;font-size:.8rem;color:var(--ink-soft);margin:16px 0 8px;}

  .notes-log{display:flex;flex-direction:column;gap:6px;margin-bottom:10px;}
  .note-item{display:flex;gap:10px;font-size:.85rem;padding:7px 11px;background:var(--steel-50);border-radius:8px;}
  .note-date{color:var(--ink-soft);white-space:nowrap;}
  .note-empty{color:var(--ink-soft);font-size:.82rem;font-style:italic;}
  .add-note-row{display:flex;gap:8px;}
  .add-note-row input{flex:1;}

  .btn{font-family:'Assistant';font-weight:600;padding:9px 16px;border-radius:var(--radius-sm);border:none;cursor:pointer;font-size:.87rem;transition:filter .15s, transform .08s;white-space:nowrap;}
  .btn:active{transform:scale(.97);}
  .btn-primary{background:var(--blue);color:#fff;}
  .btn-stamp{background:var(--teal);color:#fff;}
  .btn-ghost{background:transparent;border:1px solid var(--line);color:var(--ink);}
  .btn-danger{background:var(--red-soft);color:var(--red);}
  .btn:hover{filter:brightness(1.06);}
  .btn:disabled{opacity:.6;cursor:default;}

  .search-bar{max-width:340px;margin-bottom:16px;display:block;}
  .empty-state{background:var(--paper);border:1px dashed var(--line);border-radius:var(--radius);padding:38px;text-align:center;color:var(--ink-soft);}

  .admin-table{width:100%;border-collapse:collapse;background:var(--paper);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);}
  .admin-table th,.admin-table td{padding:9px 10px;font-size:.83rem;border-bottom:1px solid var(--line);text-align:right;}
  .admin-table th{background:var(--steel-50);font-family:'Rubik';font-weight:700;font-size:.74rem;color:var(--ink-soft);white-space:nowrap;}
  .admin-table td input,.admin-table td select{width:100%;min-width:96px;border:1px solid transparent;background:transparent;padding:5px 6px;font-size:.83rem;}
  .admin-table td input:hover,.admin-table td select:hover{border-color:var(--line);}
  .admin-table td input:focus,.admin-table td select:focus{background:#fff;border-color:var(--blue);}

  #toast-container{position:fixed;bottom:20px;inset-inline-start:20px;display:flex;flex-direction:column;gap:8px;z-index:999;}
  .toast{background:var(--graphite-900);color:#fff;padding:12px 18px;border-radius:10px;font-size:.85rem;box-shadow:var(--shadow);animation:toastIn .22s ease;max-width:320px;}
  .toast.error{background:var(--red);}
  .toast.success{background:var(--teal);}
  @keyframes toastIn{from{transform:translateY(10px);opacity:0;}to{transform:translateY(0);opacity:1;}}

  #loader{position:fixed;inset:0;background:var(--steel-50);display:flex;align-items:center;justify-content:center;font-family:'Rubik';font-weight:700;color:var(--ink-soft);z-index:1000;font-size:.95rem;}

  @media (max-width:860px){
    #app{flex-direction:column;}
    .sidebar{width:100%;height:auto;position:sticky;top:0;flex-direction:row;align-items:center;overflow-x:auto;padding:12px;gap:10px;}
    .brand{display:none;}
    .sidebar nav{flex-direction:row;margin-top:0;gap:6px;}
    .nav-btn{width:auto;}
    .sidebar-foot{display:none;}
    .content{padding:18px;}
  }
  @media (prefers-reduced-motion: reduce){
    *{animation:none !important;transition:none !important;}
  }
</style>
</head>
<body>
<div id="loader">טוען נתונים…</div>
<div id="app">
  <aside class="sidebar">
    <div class="brand"><span class="dot"></span>ניהול מלאי רכבים</div>
    <nav>
      <button class="nav-btn active" data-view="dashboard" onclick="switchView('dashboard')"><span>לוח בקרה</span></button>
      <button class="nav-btn" data-view="neworder" onclick="switchView('neworder')"><span>הזמנת רכש חדשה</span></button>
      <button class="nav-btn" data-view="garage" onclick="switchView('garage')"><span>במוסך</span><span class="badge" id="badge-garage">0</span></button>
      <button class="nav-btn" data-view="inventory" onclick="switchView('inventory')"><span>מלאי זמין</span><span class="badge" id="badge-inventory">0</span></button>
      <button class="nav-btn" data-view="delivered" onclick="switchView('delivered')"><span>נמסרו</span><span class="badge" id="badge-delivered">0</span></button>
      <button class="nav-btn" data-view="admin" onclick="switchView('admin')"><span>אדמין</span></button>
    </nav>
    <div class="sidebar-foot">איש מוסך ברירת מחדל: אהוד</div>
  </aside>

  <main class="content">

    <section id="view-dashboard" class="view">
      <div class="topbar"><h1>לוח בקרה</h1><p>תמונת מצב של כל הרכבים במערכת — מוסך, מלאי ומסירות.</p></div>
      <div class="kpi-grid" id="kpiGrid"></div>
      <h3 class="group-title">התור הבא במוסך</h3>
      <div id="queueList"></div>
    </section>

    <section id="view-neworder" class="view hidden">
      <div class="topbar"><h1>הזמנת רכש חדשה</h1><p>הדביקו את תוכן הזמנת הרכש שהתקבלה במייל, או העלו תמונה של המסמך — ולחצו על מילוי אוטומטי. אפשר גם למלא ידנית.</p></div>

      <div class="paper-block">
        <div class="field"><label>טקסט ההזמנה (מהמייל)</label><textarea id="orderRawText" rows="6" placeholder="הדביקו כאן את תוכן ההזמנה שהתקבלה במייל..."></textarea></div>
        <div class="row" style="margin-top:12px;align-items:center;">
          <button class="btn btn-primary" id="analyzeBtn" onclick="analyzeOrder()">מלא אוטומטית מהטקסט</button>
          <span id="analyzeStatus" style="font-size:.85rem;color:var(--ink-soft);"></span>
        </div>
      </div>

      <div class="paper-block" style="margin-top:18px;">
        <div class="field"><label>או העלו תמונה של המסמך (הזמנת רכש, תעודת רכב, צילום מסך וכו')</label>
          <input type="file" id="orderImageInput" accept="image/*" onchange="handleImageSelect(event)">
        </div>
        <div id="imagePreviewWrap" class="hidden" style="margin-top:12px;display:flex;align-items:center;gap:14px;">
          <img id="imagePreview" alt="תצוגה מקדימה" style="max-width:200px;max-height:200px;border-radius:10px;border:1px solid var(--line);object-fit:cover;">
          <button class="btn btn-ghost" onclick="clearImageSelection()">הסר תמונה</button>
        </div>
        <div class="row" style="margin-top:12px;align-items:center;">
          <button class="btn btn-primary" id="analyzeImageBtn" onclick="analyzeOrderImage()" disabled>מלא אוטומטית מהתמונה</button>
          <span id="analyzeImageStatus" style="font-size:.85rem;color:var(--ink-soft);"></span>
        </div>
      </div>

      <div class="paper-block" style="margin-top:18px;">
        <h3>פרטי הרכב</h3>
        <div class="row" style="margin-top:14px;">
          <div class="field"><label>מספר רכב *</label><input class="mono" id="f_car_number"></div>
          <div class="field"><label>דגם</label><input id="f_model"></div>
          <div class="field"><label>מספר הזמנה</label><input class="mono" id="f_order_number"></div>
          <div class="field"><label>תאריך כניסה למוסך</label><input type="date" id="f_entry_date"></div>
        </div>
        <div class="row">
          <div class="field" style="flex:2;min-width:280px;"><label>מה צריך לעשות ברכב</label><textarea id="f_tasks" rows="3"></textarea></div>
          <div class="field"><label>איש מוסך</label><input id="f_mechanic" value="אהוד"></div>
        </div>
        <h3 style="margin-top:6px;">פרטי לקוח</h3>
        <div class="row" style="margin-top:14px;">
          <div class="field"><label>שם לקוח</label><input id="f_customer_name"></div>
          <div class="field"><label>ת.ז.</label><input class="mono" id="f_customer_id"></div>
          <div class="field"><label>טלפון</label><input class="mono" id="f_customer_phone"></div>
        </div>
        <div class="row">
          <div class="field"><label>אימייל</label><input id="f_customer_email"></div>
          <div class="field" style="flex:2;"><label>כתובת</label><input id="f_customer_address"></div>
        </div>
        <div class="row" style="margin-top:6px;">
          <button class="btn btn-primary" onclick="submitNewCar()">הוסף למוסך</button>
          <button class="btn btn-ghost" onclick="resetNewOrderForm()">נקה טופס</button>
        </div>
      </div>
    </section>

    <section id="view-garage" class="view hidden">
      <div class="topbar"><h1>רכבים במוסך</h1><p>עבודה שוטפת אצל אהוד. עדכנו פרטים והערות, ובסיום העבודה לחצו "סיים עבודה" כדי להעביר את הרכב למלאי הזמין.</p></div>
      <input class="search-bar" id="searchGarage" placeholder="חיפוש לפי מספר רכב או שם לקוח..." oninput="renderGarage()">
      <div id="garageList"></div>
    </section>

    <section id="view-inventory" class="view hidden">
      <div class="topbar"><h1>מלאי זמין</h1><p>רכבים שסיימו טיפול. לאחר מכירה ציינו איש מכירות; לאחר מסירה בפועל ללקוח סמנו "נמסר".</p></div>
      <input class="search-bar" id="searchInventory" placeholder="חיפוש לפי מספר רכב או שם לקוח..." oninput="renderInventory()">
      <h3 class="group-title">זמינים למכירה</h3>
      <div id="invAvailableList"></div>
      <h3 class="group-title">נמכרו — ממתינים למסירה</h3>
      <div id="invSoldList"></div>
    </section>

    <section id="view-delivered" class="view hidden">
      <div class="topbar"><h1>רכבים שנמסרו</h1><p>היסטוריית מסירות. לתיקוני נתונים היכנסו לאדמין.</p></div>
      <input class="search-bar" id="searchDelivered" placeholder="חיפוש לפי מספר רכב או שם לקוח..." oninput="renderDelivered()">
      <div id="deliveredList"></div>
    </section>

    <section id="view-admin" class="view hidden">
      <div class="topbar"><h1>אדמין</h1><p>שליטה מלאה בכל הרכבים במערכת — עריכה חופשית, שינוי סטטוס, מחיקה וגיבוי.</p></div>
      <div class="row" style="justify-content:space-between;align-items:center;">
        <input class="search-bar" id="searchAdmin" style="margin-bottom:0;" placeholder="חיפוש לפי מספר רכב, שם לקוח או ת.ז..." oninput="renderAdmin()">
        <div class="row" style="margin-bottom:0;">
          <button class="btn btn-ghost" onclick="exportData()">ייצוא גיבוי (JSON)</button>
          <button class="btn btn-danger" onclick="resetAll()">איפוס כל הנתונים</button>
        </div>
      </div>
      <div style="overflow-x:auto;margin-top:14px;">
        <table class="admin-table">
          <thead><tr>
            <th>מס' רכב</th><th>דגם</th><th>סטטוס</th><th>לקוח</th><th>ת.ז.</th><th>טלפון</th>
            <th>כניסה למוסך</th><th>כניסה למלאי</th><th>איש מכירות</th><th>נמכר</th><th>נמסר</th><th></th>
          </tr></thead>
          <tbody id="adminTableBody"></tbody>
        </table>
      </div>
    </section>

  </main>
</div>
<div id="toast-container"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
const SUPABASE_URL = 'https://rvdiadvspvouysehmceg.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ2ZGlhZHZzcHZvdXlzZWhtY2VnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMyNTk1NzMsImV4cCI6MjA5ODgzNTU3M30.nUI7bcM_3Em7_iXt6x6p1IUIm7yFQRgkpDq7YkjV3kI';
const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let cars = [];
let currentView = 'dashboard';

/* ---------- helpers ---------- */
function todayStr(){ return new Date().toISOString().slice(0,10); }
function formatDateHe(dateStr){
  if(!dateStr) return '';
  const parts = dateStr.split('-');
  if(parts.length!==3) return dateStr;
  const [y,m,d] = parts;
  return `${d}/${m}/${y}`;
}
function daysSince(dateStr){
  if(!dateStr) return 0;
  const d1 = new Date(dateStr);
  const d2 = new Date(todayStr());
  return Math.max(0, Math.round((d2-d1)/(1000*60*60*24)));
}
function uid(){
  return (window.crypto && crypto.randomUUID) ? crypto.randomUUID() : ('id-'+Date.now()+'-'+Math.random().toString(36).slice(2,8));
}
function esc(s){
  return (s===undefined||s===null? '': String(s)).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function quick(id, field, value){
  const c = cars.find(x=>x.id===id);
  if(c) c[field]=value;
}
function updateCarField(id, field, value){
  quick(id, field, value);
  saveCars();
  renderAll();
}
function showToast(msg, type){
  const container = document.getElementById('toast-container');
  const div = document.createElement('div');
  div.className = 'toast ' + (type==='error'?'error':'success');
  div.textContent = msg;
  container.appendChild(div);
  setTimeout(()=>{ div.remove(); }, 3200);
}

/* ---------- storage (Supabase — shared across all devices) ---------- */
async function loadCars(){
  try{
    const { data, error } = await sb.from('cars').select('*').order('created_at', { ascending: true });
    if(error) throw error;
    cars = (data || []).map(c => ({ ...c, notes_log: c.notes_log || [] }));
  }catch(e){
    cars = cars || [];
    showToast('שגיאה בטעינת הנתונים מהשרת: ' + (e && e.message ? e.message : ''), 'error');
  }
}
async function saveCars(){
  try{
    const { error } = await sb.from('cars').upsert(cars, { onConflict: 'id' });
    if(error) throw error;
  }catch(e){
    showToast('שגיאה בשמירת הנתונים: ' + (e && e.message ? e.message : ''), 'error');
  }
}
async function deleteCarFromServer(id){
  try{
    const { error } = await sb.from('cars').delete().eq('id', id);
    if(error) throw error;
  }catch(e){
    showToast('שגיאה במחיקה מהשרת: ' + (e && e.message ? e.message : ''), 'error');
  }
}
async function resetAllOnServer(){
  try{
    const { error } = await sb.from('cars').delete().neq('id', '__none__');
    if(error) throw error;
  }catch(e){
    showToast('שגיאה באיפוס הנתונים בשרת: ' + (e && e.message ? e.message : ''), 'error');
  }
}

/* ---------- navigation ---------- */
function switchView(name){
  currentView = name;
  document.querySelectorAll('.view').forEach(v=>v.classList.add('hidden'));
  document.getElementById('view-'+name).classList.remove('hidden');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.toggle('active', b.dataset.view===name));
  loadCars().then(renderAll);
}
function renderCurrentView(){
  if(currentView==='dashboard') renderDashboard();
  else if(currentView==='garage') renderGarage();
  else if(currentView==='inventory') renderInventory();
  else if(currentView==='delivered') renderDelivered();
  else if(currentView==='admin') renderAdmin();
}
function updateBadges(){
  document.getElementById('badge-garage').textContent = cars.filter(c=>c.status==='garage').length;
  document.getElementById('badge-inventory').textContent = cars.filter(c=>c.status==='inventory').length;
  document.getElementById('badge-delivered').textContent = cars.filter(c=>c.status==='delivered').length;
}
function renderAll(){
  updateBadges();
  renderCurrentView();
}

/* ---------- dashboard ---------- */
function renderDashboard(){
  const garageCount = cars.filter(c=>c.status==='garage').length;
  const availableCount = cars.filter(c=>c.status==='inventory' && !c.sold_date).length;
  const pendingCount = cars.filter(c=>c.status==='inventory' && c.sold_date).length;
  const deliveredCount = cars.filter(c=>c.status==='delivered').length;
  const ym = todayStr().slice(0,7);
  const deliveredMonth = cars.filter(c=>c.status==='delivered' && (c.delivered_date||'').slice(0,7)===ym).length;

  document.getElementById('kpiGrid').innerHTML = `
    <div class="kpi-card" style="--c:var(--amber)"><div class="num">${garageCount}</div><div class="label"><span class="light" style="background:var(--amber)"></span>בעבודה במוסך</div></div>
    <div class="kpi-card" style="--c:var(--blue)"><div class="num">${availableCount}</div><div class="label"><span class="light" style="background:var(--blue)"></span>זמינים למכירה</div></div>
    <div class="kpi-card" style="--c:var(--teal)"><div class="num">${pendingCount}</div><div class="label"><span class="light" style="background:var(--teal)"></span>נמכרו — ממתינים למסירה</div></div>
    <div class="kpi-card" style="--c:var(--slate)"><div class="num">${deliveredMonth}</div><div class="label"><span class="light" style="background:var(--slate)"></span>נמסרו החודש (סה"כ: ${deliveredCount})</div></div>
  `;

  const queue = cars.filter(c=>c.status==='garage')
    .sort((a,b)=>(a.entry_garage_date||'').localeCompare(b.entry_garage_date||''))
    .slice(0,5);

  document.getElementById('queueList').innerHTML = queue.length ? queue.map(c=>`
    <div class="car-card" style="padding:13px 18px;">
      <div class="row" style="margin:0;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:12px;">
          <span class="plate mono">${esc(c.car_number)}</span>
          <span style="color:var(--ink-soft);font-size:.85rem;">${esc(c.model)}</span>
        </div>
        <span class="pill garage"><span class="dot"></span>${daysSince(c.entry_garage_date)} ימים במוסך</span>
      </div>
    </div>`).join('') : '<div class="empty-state">אין רכבים במוסך כרגע.</div>';
}

/* ---------- new order / AI extraction ---------- */
async function analyzeOrder(){
  const text = document.getElementById('orderRawText').value.trim();
  if(!text){ showToast('הדביקו קודם את טקסט ההזמנה', 'error'); return; }
  const btn = document.getElementById('analyzeBtn');
  const status = document.getElementById('analyzeStatus');
  btn.disabled = true; btn.textContent = 'מנתח...'; status.textContent = '';
  try{
    const prompt = `אתה עוזר למוסך רכבים לחלץ מידע מהזמנת רכש שמתקבלת במייל.
קרא את הטקסט הבא וחלץ ממנו את השדות הבאים בלבד. אם שדה לא קיים בטקסט, השאר אותו כמחרוזת ריקה.
החזר אך ורק אובייקט JSON תקין, ללא טקסט נוסף, ללא markdown, בפורמט הבא בדיוק:
{"order_number":"","car_number":"","model":"","tasks":"","customer_name":"","customer_id":"","customer_phone":"","customer_email":"","customer_address":""}

הטקסט:
"""${text}"""`;
    const resp = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        messages: [{ role: "user", content: prompt }]
      })
    });
    const data = await resp.json();
    const raw = (data.content||[]).map(b=>b.text||'').join('');
    const cleaned = raw.replace(/```json|```/g,'').trim();
    const parsed = JSON.parse(cleaned);
    fillFormFromParsed(parsed);
    status.textContent = 'הפרטים מולאו אוטומטית — בדקו ותקנו במידת הצורך לפני ההוספה.';
  }catch(e){
    showToast('לא הצלחתי לנתח את ההזמנה אוטומטית. אפשר למלא ידנית.', 'error');
  }finally{
    btn.disabled = false; btn.textContent = 'מלא אוטומטית מהטקסט';
  }
}

function fillFormFromParsed(parsed){
  document.getElementById('f_order_number').value = parsed.order_number || '';
  document.getElementById('f_car_number').value = parsed.car_number || '';
  document.getElementById('f_model').value = parsed.model || '';
  document.getElementById('f_tasks').value = parsed.tasks || '';
  document.getElementById('f_customer_name').value = parsed.customer_name || '';
  document.getElementById('f_customer_id').value = parsed.customer_id || '';
  document.getElementById('f_customer_phone').value = parsed.customer_phone || '';
  document.getElementById('f_customer_email').value = parsed.customer_email || '';
  document.getElementById('f_customer_address').value = parsed.customer_address || '';
}

/* ---------- image-based AI extraction ---------- */
let selectedImageBase64 = null;
let selectedImageMediaType = null;

function handleImageSelect(event){
  const file = event.target.files && event.target.files[0];
  if(!file) return;
  if(file.size > 8 * 1024 * 1024){
    showToast('התמונה גדולה מדי (מעל 8MB) — נסו תמונה קטנה יותר', 'error');
    event.target.value = '';
    return;
  }
  const reader = new FileReader();
  reader.onload = function(e){
    const dataUrl = e.target.result;
    selectedImageMediaType = file.type || 'image/jpeg';
    selectedImageBase64 = dataUrl.split(',')[1];
    document.getElementById('imagePreview').src = dataUrl;
    document.getElementById('imagePreviewWrap').classList.remove('hidden');
    document.getElementById('analyzeImageBtn').disabled = false;
    document.getElementById('analyzeImageStatus').textContent = '';
  };
  reader.onerror = function(){
    showToast('שגיאה בטעינת התמונה', 'error');
  };
  reader.readAsDataURL(file);
}

function clearImageSelection(){
  selectedImageBase64 = null;
  selectedImageMediaType = null;
  document.getElementById('orderImageInput').value = '';
  document.getElementById('imagePreview').src = '';
  document.getElementById('imagePreviewWrap').classList.add('hidden');
  document.getElementById('analyzeImageBtn').disabled = true;
  document.getElementById('analyzeImageStatus').textContent = '';
}

async function analyzeOrderImage(){
  if(!selectedImageBase64){ showToast('יש לבחור תמונה קודם', 'error'); return; }
  const btn = document.getElementById('analyzeImageBtn');
  const status = document.getElementById('analyzeImageStatus');
  btn.disabled = true; btn.textContent = 'מנתח תמונה...'; status.textContent = '';
  try{
    const promptText = `זו תמונה של מסמך שהתקבל אצל מוסך רכבים — יכול להיות הזמנת רכש, תעודת רכב, טופס לקוח או צילום מסך של מייל.
קרא בעיון את כל הטקסט המופיע בתמונה (בעברית ו/או אנגלית) והבן את ההקשר שלו.
חלץ מהתמונה את השדות הבאים בלבד. אם שדה מסוים לא מופיע בתמונה או לא ברור, השאר אותו כמחרוזת ריקה — אל תמציא מידע שלא מופיע בפועל.
החזר אך ורק אובייקט JSON תקין, ללא טקסט נוסף, ללא markdown, בפורמט הבא בדיוק:
{"order_number":"","car_number":"","model":"","tasks":"","customer_name":"","customer_id":"","customer_phone":"","customer_email":"","customer_address":""}`;
    const resp = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        messages: [{
          role: "user",
          content: [
            { type: "image", source: { type: "base64", media_type: selectedImageMediaType, data: selectedImageBase64 } },
            { type: "text", text: promptText }
          ]
        }]
      })
    });
    const data = await resp.json();
    const raw = (data.content||[]).map(b=>b.text||'').join('');
    const cleaned = raw.replace(/```json|```/g,'').trim();
    const parsed = JSON.parse(cleaned);
    fillFormFromParsed(parsed);
    status.textContent = 'הפרטים מולאו אוטומטית מהתמונה — בדקו ותקנו במידת הצורך לפני ההוספה.';
  }catch(e){
    showToast('לא הצלחתי לנתח את התמונה אוטומטית. אפשר למלא ידנית.', 'error');
  }finally{
    btn.disabled = false; btn.textContent = 'מלא אוטומטית מהתמונה';
  }
}

function submitNewCar(){
  const carNumber = document.getElementById('f_car_number').value.trim();
  if(!carNumber){ showToast('יש להזין מספר רכב', 'error'); return; }
  const car = {
    id: uid(),
    order_number: document.getElementById('f_order_number').value.trim(),
    car_number: carNumber,
    model: document.getElementById('f_model').value.trim(),
    tasks: document.getElementById('f_tasks').value.trim(),
    mechanic: document.getElementById('f_mechanic').value.trim() || 'אהוד',
    customer_name: document.getElementById('f_customer_name').value.trim(),
    customer_id: document.getElementById('f_customer_id').value.trim(),
    customer_phone: document.getElementById('f_customer_phone').value.trim(),
    customer_email: document.getElementById('f_customer_email').value.trim(),
    customer_address: document.getElementById('f_customer_address').value.trim(),
    notes_log: [],
    status: 'garage',
    entry_garage_date: document.getElementById('f_entry_date').value || todayStr(),
    entry_inventory_date: '',
    salesperson: '',
    sold_date: '',
    delivered_date: '',
    created_at: new Date().toISOString()
  };
  cars.push(car);
  saveCars();
  renderAll();
  resetNewOrderForm();
  showToast('הרכב נוסף למוסך בהצלחה', 'success');
  switchView('garage');
}

function resetNewOrderForm(){
  document.getElementById('orderRawText').value = '';
  ['f_order_number','f_car_number','f_model','f_tasks','f_customer_name','f_customer_id','f_customer_phone','f_customer_email','f_customer_address'].forEach(id=>{
    document.getElementById(id).value = '';
  });
  document.getElementById('f_mechanic').value = 'אהוד';
  document.getElementById('f_entry_date').value = todayStr();
  document.getElementById('analyzeStatus').textContent = '';
  clearImageSelection();
}

/* ---------- garage ---------- */
function renderGarage(){
  const container = document.getElementById('garageList');
  const q = (document.getElementById('searchGarage')?.value || '').trim().toLowerCase();
  let list = cars.filter(c=>c.status==='garage');
  if(q) list = list.filter(c => (c.car_number||'').toLowerCase().includes(q) || (c.customer_name||'').toLowerCase().includes(q));
  list.sort((a,b)=> (a.entry_garage_date||'').localeCompare(b.entry_garage_date||''));
  if(list.length===0){ container.innerHTML = '<div class="empty-state">אין כרגע רכבים במוסך.</div>'; return; }
  container.innerHTML = list.map(garageCardHTML).join('');
}
function garageCardHTML(car){
  const days = daysSince(car.entry_garage_date);
  const notesHTML = (car.notes_log||[]).map(n=>`<div class="note-item"><span class="note-date mono">${esc(formatDateHe(n.date))}</span><span>${esc(n.text)}</span></div>`).join('') || '<div class="note-empty">אין הערות עדיין</div>';
  return `
  <div class="car-card" data-card="${car.id}">
    <div class="row" style="align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <span class="plate mono">${esc(car.car_number)}</span>
        <span class="pill garage"><span class="dot"></span>במוסך · ${days} ימים</span>
        ${car.order_number ? `<span style="font-size:.78rem;color:var(--ink-soft);">הזמנה #${esc(car.order_number)}</span>` : ''}
      </div>
      <button class="btn btn-stamp" onclick="finishGarage('${car.id}')">✓ סיים עבודה — העבר למלאי</button>
    </div>
    <div class="row">
      <div class="field"><label>דגם</label><input value="${esc(car.model)}" oninput="quick('${car.id}','model',this.value)" onchange="saveCars()"></div>
      <div class="field"><label>איש מוסך</label><input value="${esc(car.mechanic)}" oninput="quick('${car.id}','mechanic',this.value)" onchange="saveCars()"></div>
      <div class="field"><label>תאריך כניסה למוסך</label><input type="date" value="${esc(car.entry_garage_date)}" onchange="updateCarField('${car.id}','entry_garage_date',this.value)"></div>
    </div>
    <div class="field"><label>מה צריך לעשות ברכב</label><textarea rows="2" oninput="quick('${car.id}','tasks',this.value)" onchange="saveCars()">${esc(car.tasks)}</textarea></div>
    <div class="section-label">פרטי לקוח</div>
    <div class="row">
      <div class="field"><label>שם</label><input value="${esc(car.customer_name)}" oninput="quick('${car.id}','customer_name',this.value)" onchange="saveCars()"></div>
      <div class="field"><label>ת.ז.</label><input class="mono" value="${esc(car.customer_id)}" oninput="quick('${car.id}','customer_id',this.value)" onchange="saveCars()"></div>
      <div class="field"><label>טלפון</label><input class="mono" value="${esc(car.customer_phone)}" oninput="quick('${car.id}','customer_phone',this.value)" onchange="saveCars()"></div>
    </div>
    <div class="row">
      <div class="field"><label>אימייל</label><input value="${esc(car.customer_email)}" oninput="quick('${car.id}','customer_email',this.value)" onchange="saveCars()"></div>
      <div class="field" style="flex:2;"><label>כתובת</label><input value="${esc(car.customer_address)}" oninput="quick('${car.id}','customer_address',this.value)" onchange="saveCars()"></div>
    </div>
    <div class="section-label">הערות</div>
    <div class="notes-log">${notesHTML}</div>
    <div class="add-note-row">
      <input type="text" id="noteInput-${car.id}" placeholder="הוסף הערה חדשה...">
      <button class="btn btn-ghost" onclick="addNote('${car.id}')">הוסף הערה</button>
    </div>
  </div>`;
}
function addNote(id){
  const input = document.getElementById('noteInput-'+id);
  const text = input.value.trim();
  if(!text) return;
  const car = cars.find(c=>c.id===id);
  if(!car) return;
  if(!car.notes_log) car.notes_log = [];
  car.notes_log.push({ id: uid(), date: todayStr(), text });
  saveCars();
  renderCurrentView();
}
function finishGarage(id){
  const card = document.querySelector(`[data-card="${id}"]`);
  if(card) card.classList.add('stamping');
  setTimeout(()=>{
    const car = cars.find(c=>c.id===id);
    if(car){ car.status = 'inventory'; car.entry_inventory_date = todayStr(); }
    saveCars();
    renderAll();
    showToast('הרכב הועבר למלאי הזמין', 'success');
  }, 480);
}

/* ---------- inventory ---------- */
function renderInventory(){
  const q = (document.getElementById('searchInventory')?.value || '').trim().toLowerCase();
  let list = cars.filter(c=>c.status==='inventory');
  if(q) list = list.filter(c => (c.car_number||'').toLowerCase().includes(q) || (c.customer_name||'').toLowerCase().includes(q));
  const available = list.filter(c=>!c.sold_date).sort((a,b)=>(a.entry_inventory_date||'').localeCompare(b.entry_inventory_date||''));
  const sold = list.filter(c=>c.sold_date).sort((a,b)=>(b.sold_date||'').localeCompare(a.sold_date||''));
  document.getElementById('invAvailableList').innerHTML = available.length ? available.map(availableCardHTML).join('') : '<div class="empty-state">אין רכבים זמינים כרגע.</div>';
  document.getElementById('invSoldList').innerHTML = sold.length ? sold.map(soldCardHTML).join('') : '<div class="empty-state">אין רכבים בהמתנה למסירה.</div>';
}
function availableCardHTML(car){
  return `<div class="car-card" data-card="${car.id}">
    <div class="row" style="align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <span class="plate mono">${esc(car.car_number)}</span>
        <span class="pill inventory"><span class="dot"></span>במלאי מ-${esc(formatDateHe(car.entry_inventory_date))}</span>
      </div>
    </div>
    <div class="row">
      <div class="field"><label>דגם</label><span class="static-val">${esc(car.model)||'—'}</span></div>
      <div class="field"><label>לקוח קודם</label><span class="static-val">${esc(car.customer_name)||'—'}</span></div>
      <div class="field"><label>מה נעשה במוסך</label><span class="static-val">${esc(car.tasks)||'—'}</span></div>
